{
   "name": "ai-codelint",
   "publisher": "russell-gn",
   "version": "0.0.9",
   "description": "Use LLMs to lint code.",
   "icon": "./assets/logo.png",
   "categories": [
      "AI",
      "Linters"
   ],
   "keywords": [
      "AI",
      "linter",
      "tower-lsp"
   ],
   "license": "MIT",
   "repository": {
      "url": "https://github.com/RussellGN/AI-CodeLint"
   },
   "main": "./dist/extension.js",
   "scripts": {
      "postinstall": "cd client && pnpm i",
      "compile": "npm run check-types && cross-env NODE_ENV=production rolldown -c",
      "check-types": "tsc --noEmit",
      "watch": "npm-run-all -p watch:*",
      "watch:rolldown": "rolldown --watch -c",
      "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
      "package": "vsce package --no-dependencies",
      "publish": "vsce publish --no-dependencies",
      "lint": "oxlint -c oxlint.json .",
      "fmt": "oxfmt --write .",
      "fmt:check": "oxfmt --check ."
   },
   "devDependencies": {
      "@types/glob": "8.1.0",
      "@types/node": "22.10.2",
      "@vscode/vsce": "^3.2.1",
      "cross-env": "^7.0.2",
      "glob": "11.0.0",
      "mocha": "11.0.2",
      "npm-run-all": "^4.1.5",
      "oxfmt": "^0.24.0",
      "oxlint": "^1.39.0",
      "rolldown": "^1.0.0-rc.6",
      "ts-loader": "^9.5.1",
      "typescript": "5.4.5",
      "vscode-test": "^1.4.0",
      "vscode-uri": "^3.0.2"
   },
   "engines": {
      "vscode": "^1.66.0"
   },
   "activationEvents": [
      "onLanguage"
   ],
   "contributes": {
      "configuration": {
         "type": "object",
         "title": "ai-codelint",
         "properties": {
            "ai-codelint.trace.server": {
               "type": "string",
               "scope": "window",
               "enum": [
                  "off",
                  "messages",
                  "verbose"
               ],
               "enumDescriptions": [
                  "No traces",
                  "Error only",
                  "Full log"
               ],
               "default": "messages",
               "description": "Traces the communication between VS Code and the linter."
            }
         }
      }
   },
   "packageManager": "pnpm@8.15.7",
   "enabledApiProposals": []
}
