      // Re-enable once test output/fixtures are reintroduced under clients/vs-code.
      // {
      //   "name": "Language Server E2E Test",
      //   "type": "extensionHost",
      //   "request": "launch",
      //   "runtimeExecutable": "${execPath}",
      //   "args": [
      //     "--extensionDevelopmentPath=${workspaceRoot}/clients/vs-code",
      //     "--extensionTestsPath=${workspaceRoot}/clients/vs-code/out/test/index",
      //     "${workspaceRoot}/clients/vs-code/testFixture"
      //   ],
      //   "outFiles": ["${workspaceRoot}/clients/vs-code/out/test/**/*.js"]
      // }
   ],
   "compounds": [
      {
         "name": "Client + Server",
         "configurations": [
            "Launch Client"
            // "Attach to Server"
         ]
      }
   ]
}
